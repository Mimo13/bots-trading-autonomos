# ──────────────────────────────────────────────
# Variables de entorno para bots de trading
# Copia este fichero como .env y rellena los valores
# ──────────────────────────────────────────────

# TradingView MCP (para análisis técnico)
# No necesita API key si usas tradingview-mcp-server local
TV_MCP_HOST=localhost
TV_MCP_PORT=18789

# Binance API (para obtener OHLCV y precios en tiempo real)
# Las claves solo son necesarias para endpoints autenticados
# Market data pública NO necesita API key
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Base de datos del dashboard
DATABASE_URL=postgresql:///bots_dashboard

# Assets a trackear (separados por comas)
# Símbolos disponibles: BTCUSDT, ETHUSDT, SOLUSDT, ADAUSDT, DOGEUSDT, LINKUSDT
WATCH_ASSETS=BTCUSDT,SOLUSDT,ADAUSDT,DOGEUSDT

# Intervalo de velas (1m, 5m, 15m, 30m, 1h, 4h, 1d, 1w)
CANDLE_INTERVAL=5m

# Número de velas a obtener
CANDLE_LIMIT=500
